<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileSnapshotUI.Pages.RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileSnapshotUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileSnapshotUI.Models"
    mc:Ignorable="d">

    <Grid Padding="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="1"
            Width="1"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

        <Grid Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Grid Grid.Row="0" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Add -->
                <Button
                    Grid.Column="0"
                    Click="AddButton_Click"
                    Margin="0,0,8,0">

                    <FontIcon Glyph="&#xE710;"/>
                </Button>

                <!-- Delete -->
                <Button
                    x:Name="DeleteButton"
                    Grid.Column="1"
                    Click="DeleteButton_Click"
                    IsEnabled="{x:Bind RootViewModel.SelectedFile.IsNotProcessing, Mode=OneWay, FallbackValue=False}">

                    <FontIcon Glyph="&#xE74D;"/>
                </Button>

                <!-- Settings -->
                <Button
                    Grid.Column="3"
                    Click="SettingsButton_Click"
                    Margin="0,0,8,0">

                    <FontIcon Glyph="&#xE713;"/>
                </Button>
                
                <!-- Notifications -->
                <Button 
                    Grid.Column="4"
                    Click="NotificationButton_Click">
                    <Grid>
                        <FontIcon Glyph="&#xEA8F;"/>

                        <InfoBadge 
                            Value="{x:Bind RootViewModel.UnreadCount, Mode=OneWay}"
                            Visibility="{x:Bind RootViewModel.HasUnreadNotifications, Mode=OneWay}"
                            Style="{ThemeResource AttentionValueInfoBadgeStyle}"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top" 
                            Margin="0,-4,-4,0"/>
                    </Grid>
                </Button>
            </Grid>

            <!-- File List -->
            <ListView
                x:Name="FilesListView"
                Grid.Row="1"
                ItemsSource="{x:Bind RootViewModel.Files}"
                SelectionChanged="FilesListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileItem">
                        <StackPanel Orientation="Horizontal" Padding="8,4">
                            <ImageIcon Width="48" Height="48" Source="{x:Bind IconGlyphPath, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Bind FileName, Mode=OneWay}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Divider -->
        <Border
        Grid.Column="1"
        Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

        <!-- Right Panel -->
        <Grid Grid.Column="2" Padding="20,20,20,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <Button 
                        x:Name="CreateSnapshotButton"
                        Grid.Column="1"
                        Click="CreateSnapshot_Click"
                        IsEnabled="{x:Bind RootViewModel.SelectedFile.IsNotProcessing, Mode=OneWay, FallbackValue=False}"
                        Content="Create Snapshot" />
                </Grid>

                <Frame x:Name="DetailsFrame" Grid.Row="1" Margin="0,10,0,10">
                    <!--ContentPresenter x:Name="DetailsPresenter"/-->
                </Frame>

                <Grid Grid.Row="2" x:Name="LastBackupStringUI" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="2" Grid.Column="1">
                        <TextBlock
                            Text="Last Backup:" 
                            Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock
                            Text="{x:Bind RootViewModel.SelectedFileLastBackup, Mode=OneWay}" 
                            Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
