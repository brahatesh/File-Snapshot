<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileSnapshotUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileSnapshotUI.Pages"
    xmlns:models="using:FileSnapshotUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    
    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Text="Settings"
            Style="{StaticResource TitleTextBlockStyle}"
            Margin="0,0,0,10" />

        <ScrollViewer 
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="50">
                <StackPanel x:Name="FileSettingsPanel">
                    <TextBlock
                        Text="File settings"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Margin="0,0,0,10" />
                    
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="File Path"
                                Style="{StaticResource BodyLargeTextBlockStyle}" 
                                Grid.Column="0" 
                                VerticalAlignment="Center"/>

                            <TextBlock
                                Text="{x:Bind ViewModel.SelectedFile.FullPath, Mode=OneWay}" 
                                x:Name="SettingsFullPath"
                                Grid.Column="1" 
                                VerticalAlignment="Center"/>

                            <Button
                                x:Name="SettingsEditFullPath"
                                Grid.Column="2"
                                Click="SettingsEditFullPath_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE70F;" />
                            </Button>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="Backup Path"
                                Style="{StaticResource BodyLargeTextBlockStyle}" 
                                Grid.Column="0" 
                                VerticalAlignment="Center"/>

                            <TextBlock
                                Text="{x:Bind ViewModel.SelectedFile.BackupPath, Mode=OneWay}" 
                                x:Name="SettingsBackupPath"
                                Grid.Column="1" 
                                VerticalAlignment="Center"/>

                            <Button
                                x:Name="SettingsEditBackupPath"
                                Grid.Column="2"
                                Click="SettingsEditBackupPath_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE70F;" />
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBox 
                                    x:Name="BackupDuration" 
                                    PlaceholderText="e.g., 1d 2h 30m" 
                                    Header="Snapshot Duration"
                                    VerticalAlignment="Center"/>

                                <TextBlock 
                                    x:Name="BackupDurationError" 
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Visibility="Collapsed"
                                    Margin="0,4,0,0" />
                            </StackPanel>
                            <Button 
                                Grid.Column="1"
                                Click="SaveBackupDuration_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                VerticalAlignment="Bottom">
                                <FontIcon Glyph="&#xE105;" />
                            </Button>
                                
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <StackPanel>
                    <TextBlock
                        Text="Application settings"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Margin="0,0,0,10" />

                    <StackPanel>
                        <ToggleSwitch 
                            x:Name="TrayIconToggle"
                            Header="Show System Tray Icon"
                            IsOn="True"
                            Toggled="TrayIconToggle_Toggled"/>

                        <ToggleSwitch 
                            x:Name="MinimizeToTrayToggle"
                            Header="Minimize to System Tray"
                            IsOn="True"
                            Toggled="MinimizeToTrayToggle_Toggled"/>

                        <ToggleSwitch 
                            x:Name="CloseButtonTrayToggle"
                            Header="Close Button Minimizes to System Tray"
                            IsOn="True"
                            Toggled="CloseToMinimizesInTrayToggle_Toggled"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
