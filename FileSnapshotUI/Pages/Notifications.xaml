<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileSnapshotUI.Pages.Notifications"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileSnapshotUI.Pages"
    xmlns:models="using:FileSnapshotUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock
            Text="Notifications"
            Style="{StaticResource TitleTextBlockStyle}"
            Margin="0,0,0,10" />
            
        <!-- Notifications List -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Notifications}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Notification">
                        <Border
                            Padding="12"
                            Margin="0,0,0,8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" >

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                    
                                <!-- File Icon -->
                                <ImageIcon
                                    Grid.Column="0"
                                    Width="48"
                                    Height="48"
                                    Source="{Binding FileItem.IconGlyphPath}"
                                    VerticalAlignment="Top" />
                                    
                                <!-- Content -->
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Top"
                                    Spacing="4">
                                    <TextBlock
                                        Text="{Binding FileItem.FileName}"
                                        Style="{StaticResource SubtitleTextBlockStyle}"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Text="{Binding Message}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Text="{Binding CreatedAtLocal}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                    
                                <!-- Actions -->
                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Top"
                                    Spacing="8">
                                    <Button
                                        Content="Open"
                                        Click="OnNotificationClicked"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Width="88" />
                                    <Button
                                        Content="Remove"
                                        Click="OnRemoveNotification"
                                        Width="88" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
            
            <!-- Empty State -->
        <StackPanel
                x:Name="EmptyState"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding Notifications.Count, Converter={StaticResource CollectionLengthToVisibilityConverter}, ConverterParameter=Inverse}">
            <TextBlock
                    Text="No notifications"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
