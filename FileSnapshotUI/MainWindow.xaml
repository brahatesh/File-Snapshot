<Window
    x:Class="FileSnapshotUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileSnapshotUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!-- Button styling -->
            <Style x:Key="DrawerTabButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource SystemControlBackgroundAltHighBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                <Setter Property="BorderThickness" Value="1,1,0,1" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}" />
                <Setter Property="CornerRadius" Value="8,0,0,8" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <!-- Opens storyboard: slide panel in and scrim fade in-->
            <Storyboard x:Name="OpenDrawerStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="RightPanelTransform"
                    Storyboard.TargetProperty="X"
                    Duration="0:0:0.28"
                    EnableDependentAnimation="True" />
                <DoubleAnimation
                    Storyboard.TargetName = "TabTransform"
                    Storyboard.TargetProperty="X"
                    Duration="0:0:0.28"
                    EnableDependentAnimation="True" />
                <DoubleAnimation
                    Storyboard.TargetName="Scrim"
                    Storyboard.TargetProperty="Opacity"
                    Duration="0:0:0.28"
                    EnableDependentAnimation="True" />
            </Storyboard>

            <!-- Close storyboard: slide panel out and scrim fade out -->
            <Storyboard x:Name="CloseDrawerStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="RightPanelTransform"
                    Storyboard.TargetProperty="X"
                    Duration="0:0:0.22"
                    EnableDependentAnimation="True" />
                <DoubleAnimation
                    Storyboard.TargetName="TabTransform"
                    Storyboard.TargetProperty="X"
                    Duration="0:0:0.22"
                    EnableDependentAnimation="True" />
                <DoubleAnimation
                    Storyboard.TargetName="Scrim"
                    Storyboard.TargetProperty="Opacity"
                    Duration="0:0:0.22"
                    EnableDependentAnimation="True" />
            </Storyboard>
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <!-- Title Bar -->
            <RowDefinition Height="Auto" />
            <!-- App Content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <TitleBar x:Name="AppTitleBar"
              Title="File Snapshot">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Icon.ico"/>
            </TitleBar.IconSource>
        </TitleBar>
        
        <!-- Main content Frame -->
        <Frame x:Name="RootFrame" Grid.Row="1" />

        <Grid x:Name="DrawerRoot" 
              Grid.Row="1"
              Visibility="Collapsed" 
              IsHitTestVisible="False"
              Canvas.ZIndex="100">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <!-- Scrim -->
            <Rectangle Grid.Column="0"
                       Grid.ColumnSpan="2"
                       x:Name="Scrim"
                       Fill="#80000000"
                       Opacity="0"
                       Tapped="Scrim_Tapped"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />

            <Border Grid.Column="1"
                    x:Name="RightDrawerBorder"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Canvas.ZIndex="110">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="RightPanelTransform" X="0" />
                </Border.RenderTransform>

                <Grid x:Name="RightPanelGrid" RenderTransformOrigin="0,0">
                    <Frame x:Name="RightPanelFrame" />
                </Grid>
            </Border>

            <!-- Arrow for closing Drawer -->
            <Button
                x:Name="DrawerTabButton"
                Grid.Column="0"
                Click="DrawerTabButton_Click"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Width="40"
                Height="60"
                Margin="0,0,0,0"
                Canvas.ZIndex="120"
                Style="{StaticResource DrawerTabButtonStyle}"                
                AutomationProperties.Name="Close Drawer"
                ToolTipService.ToolTip="Close">
                <Button.RenderTransform>
                    <TranslateTransform x:Name="TabTransform" X="0" />
                </Button.RenderTransform>
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76C;" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
        </Grid>

        <!-- Right Drawer -->
            <!--Border Grid.Column="1" 
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="RightPanelTransform" X="0" />
                </Border.RenderTransform>

                <Grid x:Name="RightPanelGrid" RenderTransformOrigin="0,0">
                    <StackPanel>
                        <Frame x:Name="RightPanelFrame" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid-->

        <!--NavigationView 
            x:Name="NavView"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            SelectionChanged="NavView_SelectionChanged">

                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Home" Icon="Home" Tag="home"/>
                </NavigationView.MenuItems>

                <NavigationView.FooterMenuItems/>

                <Frame x:Name="RootFrame"/>
            </NavigationView-->

    </Grid>
</Window>